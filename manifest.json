{
  "name": "Apna Store",
  "short_name": "Apna Store",
  "description": "A modern PWA for local shops and services.",
  "id": "/index.html",
  "start_url": "/index.html",
  "display": "standalone",
  "orientation": "portrait-primary",
  "background_color": "#ffffff",
  "theme_color": "#4a90e2",
  "icons": [
    {
      "src": "/src/assets/logos/app-logo-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/src/assets/logos/app-logo-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "screenshots": [
    {
      "src": "/src/assets/screenshots/guest-home.jpg",
      "sizes": "720x1600",
      "type": "image/jpg",
      "form_factor": "narrow",
      "label": "Welcome to Apna Store"
    },
    {
      "src": "/src/assets/screenshots/guest-account.jpg",
      "sizes": "720x1600",
      "type": "image/jpg",
      "form_factor": "narrow",
      "label": "Welcome to Apna Store"
    },    
    {
      "src": "/src/assets/screenshots/desktop-guest-home.png",
      "sizes": "1920x1080",
      "type": "image/jpg",
      "form_factor": "wide",
      "label": "Apna Store on Desktop"
    }
  ],
  "shortcuts": [
    {
      "name": "Explore Items",
      "url": "/#guest/home",
      "icons": [{ "src": "/src/assets/icons/navigation/home.svg", "sizes": "150x150" }]
    },
    {
      "name": "View My Cart",
      "url": "/#guest/account",
      "icons": [{ "src": "/src/assets/icons/navigation/user-account.svg", "sizes": "150x150" }]
    }
  ]
}
